# Postgres
DATABASE_URL=postgresql://banchan:banchan@localhost:5432/banchan

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Where uploaded files live (relative to project root or absolute)
UPLOAD_DIR=./uploads
MAX_IMAGE_BYTES=10485760   # 10 MiB

# Site
SITE_NAME=Banchan
# A random secret for signing cookies/csrf (change in prod!)
SECRET_KEY=change-me-please-use-a-long-random-string

# Boards seeded by scripts/seed.py (comma-separated slugs)
SEED_BOARDS=b,g,tech,a,mu,lit,sci,sp,v,int
